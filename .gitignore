components/t3-overlay/
components/t3code-overlay/

# Ignore ad-hoc Markdown notes/idea files outside documentation.
*.md
!README.md
!docs/*.md
!docs/**/*.md
# Track first-class component metadata/docs despite the broad Markdown ignore.
!components/COMPONENTS.md
!components/components.toml
!components/**/README.md
!components/**/*.md

# Track root license/notice files and license directory despite broad Markdown ignore.
!NOTICE
!THIRD_PARTY_NOTICES.md
!licenses/
!licenses/**
plan.md

# Tauri-generated schema/cache output.
components/desktop/src-tauri/gen/
